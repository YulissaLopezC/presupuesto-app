// ============================================================
// firestore.rules
// Reglas de seguridad para Firestore.
// Cada usuario SOLO puede leer y escribir sus propios datos.
// Sube este archivo en Firebase Console > Firestore > Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regla base: nadie puede acceder a nada por defecto
    match /{document=**} {
      allow read, write: if false;
    }

    // Cada usuario solo puede acceder a su propio árbol de datos
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
